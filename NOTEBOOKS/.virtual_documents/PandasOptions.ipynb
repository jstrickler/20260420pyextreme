# %load imports
import numpy as np
import scipy as sp
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib as mpl
%matplotlib inline
import seaborn as sns
sns.set()




x = pd.describe_option(_print_desc=False)
print(x[:500])





import re
rx_settings = re.compile(r"[a-z]+\..*\s:")


data = x.splitlines()
data[:60]
settings = []
current_setting = []
for line in data:
    if rx_settings.match(line):
        if current_setting:
            current_setting[0:1] = current_setting[0].split(' : ')
            settings.append(tuple(current_setting))
            current_setting.clear()
    current_setting.append(line.strip())
        
settings[:10]
len(settings)


pd.describe_option()



